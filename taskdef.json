{
  "family": "react-app-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::806169617511:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "react-app",
      "image": "806169617511.dkr.ecr.us-east-1.amazonaws.com/tech2102-project-group13:latest",
      "portMappings": [
        {
          "containerPort": 80,
          "protocol": "tcp"
        }
      ],
      "essential": true
    }
  ]
}